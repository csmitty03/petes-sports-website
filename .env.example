# Lightspeed Retail (X-Series) — used only by scripts/sync-lightspeed.mjs
# Copy to .env.local and fill in. Never commit real tokens.

# Store subdomain, e.g. if you open https://mystore.retail.lightspeed.app → mystore
LIGHTSPEED_DOMAIN_PREFIX=your-store-prefix

# Personal Token (Plus plan) or OAuth access token with products:read
LIGHTSPEED_TOKEN=your-personal-token-here

# API version path segment (default 2026-07 per X-Series dated API)
# LIGHTSPEED_API_VERSION=2026-07

# CI only: allow deploy to succeed without secrets (keeps existing catalog)
# LIGHTSPEED_SYNC_OPTIONAL=1
